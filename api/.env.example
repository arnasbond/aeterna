PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Parapijos komisija (basis points, 2000 = 20%)
AETERNA_PARISH_COMMISSION_BPS=2000
PUBLIC_WEB_URL=http://localhost:3000

# Slaptažodžių tikrinimas (numatyta išjungta testavimui). Įjungti: AETERNA_REQUIRE_PASSWORDS=1
# AETERNA_REQUIRE_PASSWORDS=1

# Administratorius — parapijos administratorių užklausų patvirtinimas (/admin)
AETERNA_ADMIN_PASSWORD=keiskite-stipru-slaptazodi

# Laikino klebono slaptažodžio galiojimas (valandos, numatyta 72)
PRIEST_TEMP_PASSWORD_HOURS=72

# DATABASE_URL=postgresql://...
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
