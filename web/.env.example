# Lokaliai naudokite web/.env.local — žr. .env.local.example
API_INTERNAL_URL=http://127.0.0.1:4000

# Slaptažodžių tikrinimas (numatyta išjungta). Įjungti: NEXT_PUBLIC_AETERNA_REQUIRE_PASSWORDS=1
# NEXT_PUBLIC_AETERNA_REQUIRE_PASSWORDS=1

# Viešas svetainės adresas (Vercel / production)
# NEXT_PUBLIC_SITE_URL=https://aeterna-mauve.vercel.app

# Tiesioginė Android APK (nebūtina — generuojama iš API)
# NEXT_PUBLIC_APK_URL=https://api-three-chi-63.vercel.app/api/v1/app/android/download

# Telefonas per WiFi: atidarykite http://JŪSŲ_IP:3000 (npm run dev:lan), ne :4000
# NEXT_PUBLIC_API_URL=http://192.168.1.42:4000
